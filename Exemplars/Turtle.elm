animationPieces pieces default t =
  case pieces of
    (duration, shape) :: rest ->
      if t <= duration then shape t
      else animationPieces rest default (t - duration)
    [] -> default t

add (x,y) (u,v) = (x+u,y+v)
sub (x,y) (u,v) = (x-u,y-v)
scale s (x,y) = (s*x,s*y)

