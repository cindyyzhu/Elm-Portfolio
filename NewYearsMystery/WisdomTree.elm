import WiseOwl
import SpeechBubbles exposing (speechBubbleRight, shantellSansFont) -- Your shapes go here!
type Actor = Robot 

script = 
  [ (Robot,"Ah so you desire to know what ")
  , (Robot, "Addy is doing? ")
  , (Robot, "I can’t reveal it so simply. ")
  , (Robot, "Instead I give you this riddle: ")
  , (Robot, "“The earth will yield if you")
  , (Robot, "prepare, with tools and knowledge")
  , (Robot, "gathered there. A place for seeds,")
  , (Robot, "for roots to hold, where hands are")
  , (Robot, "safe and waters cold.”")  
  ] 
  
myShapes model =
  [
     wisdomTree model
  ]
  
wisdomTree model = group
 [
  ground, sky,
    snowFalling model.time
    ,
    tree
    |> move (25,0)
    |> scale 1.2
    , 
    snow
    |> move (25,0)
    |> scale 1.2
    ,
    WiseOwl.wiseowl 
    |> scale 0.4
    |> move (16,-5)
    ,
    speechBubbleRight(solid 0.5) black (shantellSansFont) script 35 Robot (0.8*model.time)
      |> scale 1
      |> move (-30,22) 
 ]
  
