type Actor = Robot | Lily | Bark

script = 
  [ (Robot,"Hey, good morning. It’s good that you are here.")
  , (Robot, "Lily was just telling me about a note that Addy")
  , (Robot, "gave to her in school.")
  , (Lily, "Isn’t it so strange?")
  , (Lily, "Oh! I forgot to tell you, we just ")
  , (Lily, "saw Addy a few minutes ago.")
  , (Lily, "She came by to borrow  ")
  , (Lily, "my wagon.")
  , (Bark, "Woof! She looked ")
  , (Bark, "really busy.")
  , (Robot, "Hmm, I wonder what she is up to.")
  , (Robot, " Whatever it is, I hope she is staying safe.")
  ] 
